<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.5</version>
        <relativePath/>
    </parent>
    <groupId>com.github.sbracely</groupId>
    <artifactId>extended-problem-detail</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>Extended Problem Detail Parent</name>
    <description>Parent POM for Extended Problem Detail - Spring Boot Starter providing enhanced ProblemDetail exception handling with field-level error information</description>
    <url>https://github.com/sbracely/extended-problem-detail</url>
    <licenses>
        <license>
            <name>Apache License, Version 2.0</name>
            <url>https://www.apache.org/licenses/LICENSE-2.0</url>
        </license>
    </licenses>
    <developers>
        <developer>
            <name>sbrace</name>
            <email>sbrace0822@gmail.com</email>
        </developer>
    </developers>
    <scm>
        <connection>scm:git:https://github.com/sbracely/extended-problem-detail.git</connection>
        <developerConnection>scm:git:git@github.com:sbracely/extended-problem-detail.git</developerConnection>
        <tag>HEAD</tag>
        <url>https://github.com/sbracely/extended-problem-detail</url>
    </scm>
    <properties>
        <extended-problem-detail.version>0.0.1-SNAPSHOT</extended-problem-detail.version>
    </properties>

    <modules>
        <module>core</module>
        <module>autoconfigure-webmvc</module>
        <module>autoconfigure-webflux</module>
        <module>starter-webmvc</module>
        <module>starter-webflux</module>
    </modules>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.github.sbracely</groupId>
                <artifactId>extended-problem-detail-core</artifactId>
                <version>${extended-problem-detail.version}</version>
            </dependency>
            <dependency>
                <groupId>com.github.sbracely</groupId>
                <artifactId>extended-problem-detail-autoconfigure-webmvc</artifactId>
                <version>${extended-problem-detail.version}</version>
            </dependency>
            <dependency>
                <groupId>com.github.sbracely</groupId>
                <artifactId>extended-problem-detail-autoconfigure-webflux</artifactId>
                <version>${extended-problem-detail.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

</project>
