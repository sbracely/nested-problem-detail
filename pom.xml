<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.5</version>
        <relativePath/>
    </parent>
    <groupId>com.github.sbrace-git</groupId>
    <artifactId>nested-problem-detail</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>nested-problem-detail</name>
    <description>Spring Boot Starter for nested ProblemDetail exception handling</description>
    <url>https://github.com/sbrace-git/nested-problem-detail</url>
    <licenses>
        <license/>
    </licenses>
    <developers>
        <developer/>
    </developers>
    <scm>
        <connection/>
        <developerConnection/>
        <tag/>
        <url/>
    </scm>
    <properties>
        <java.version>25</java.version>
        <nested-problem-detail.version>0.0.1-SNAPSHOT</nested-problem-detail.version>
    </properties>

    <modules>
        <module>nested-problem-detail-autoconfigure</module>
        <module>nested-problem-detail-spring-boot-starter</module>
        <module>nested-problem-detail-test-mvc</module>
        <module>nested-problem-detail-test-flux</module>
    </modules>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.github.sbrace-git</groupId>
                <artifactId>nested-problem-detail-autoconfigure</artifactId>
                <version>${nested-problem-detail.version}</version>
            </dependency>
            <dependency>
                <groupId>com.github.sbrace-git</groupId>
                <artifactId>nested-problem-detail-spring-boot-starter</artifactId>
                <version>${nested-problem-detail.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!-- 父POM中不声明具体依赖，由子模块管理 -->
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>
